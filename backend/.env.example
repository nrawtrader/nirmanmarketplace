# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nirman?retryWrites=true&w=majority

# ─── JWT Secret ───────────────────────────────────────────
# Any long random string — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_change_this

# ─── MSG91 (Indian SMS for OTP) ───────────────────────────
# Sign up free at https://msg91.com
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=NIRMAN

# ─── Razorpay (Payments) ──────────────────────────────────
# Sign up free at https://razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:8080
